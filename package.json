{
  "name": "itera",
  "version": "1.0.0",
  "description": "ITERA — a disposable identity browser. Every launch begins again.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win && node -e \"require('fs').renameSync('dist/ITERA-Setup.exe','ITERA-Setup.exe')\"",
    "build:dir": "electron-builder --dir",
    "update": "powershell -ExecutionPolicy Bypass -File scripts/update-installed.ps1"
  },
  "author": "ITERA",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.itera.browser",
    "productName": "ITERA",
    "files": [
      "src/**/*",
      "scripts/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/renderer/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ITERA-Setup.${ext}"
    }
  }
}
